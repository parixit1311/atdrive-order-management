@{
    ViewData["Title"] = "Order not found";
}

<div class="text-center py-5">
    <h1 class="h3">Order not found</h1>
    <p class="text-muted">
        Sorry, we couldn't find order #@ViewBag.OrderId. It may have been deleted or the link is incorrect.
    </p>
    <a class="btn btn-primary" asp-controller="Orders" asp-action="Index">Back to orders</a>
</div>
