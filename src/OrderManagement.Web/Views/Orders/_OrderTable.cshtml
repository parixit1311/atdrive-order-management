@model List<OrderSummaryViewModel>

@if (Model.Count == 0)
{
    <div class="alert alert-info">No orders match the current filter.</div>
}
else
{
    <table class="table table-striped table-hover align-middle">
        <thead>
            <tr>
                <th>#</th>
                <th>Customer</th>
                <th>Order Date</th>
                <th>Status</th>
                <th class="text-end">Items</th>
                <th class="text-end">Total</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var order in Model)
            {
                <tr>
                    <td>@order.OrderId</td>
                    <td>@order.CustomerName</td>
                    <td>@order.OrderDate.ToString("dd MMM yyyy")</td>
                    <td>
                        <span class="badge @GetStatusBadge(order.Status)">@order.Status</span>
                    </td>
                    <td class="text-end">@order.ItemCount</td>
                    <td class="text-end">@order.Total.ToString("C")</td>
                    <td class="text-end">
                        <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@order.OrderId">Details</a>
                        <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@order.OrderId">Edit</a>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <form class="d-inline" asp-action="Delete" asp-route-id="@order.OrderId" method="post"
                                  onsubmit="return confirm('Delete order #@order.OrderId for @order.CustomerName?');">
                                <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                            </form>
                        }
                        else
                        {
                            <a class="btn btn-sm btn-outline-danger disabled" aria-disabled="true"
                               title="Sign in to delete orders">Delete</a>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@functions {
    private static string GetStatusBadge(OrderStatus status) => status switch
    {
        OrderStatus.Pending => "bg-warning text-dark",
        OrderStatus.Processing => "bg-info text-dark",
        OrderStatus.Shipped => "bg-primary",
        OrderStatus.Completed => "bg-success",
        OrderStatus.Cancelled => "bg-secondary",
        _ => "bg-light text-dark"
    };
}
