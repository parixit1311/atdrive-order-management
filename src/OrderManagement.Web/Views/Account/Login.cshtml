@model LoginViewModel
@{
    ViewData["Title"] = "Sign in";
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <h1 class="h3 mb-3">Sign in</h1>
        <p class="text-muted">Signing in is required to delete orders. Demo credentials: <code>admin</code> / <code>Admin@123</code></p>

        <form asp-action="Login" asp-route-returnUrl="@ViewBag.ReturnUrl" method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <div class="mb-3">
                <label asp-for="Username" class="form-label"></label>
                <input asp-for="Username" class="form-control" autofocus />
                <span asp-validation-for="Username" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Password" class="form-label"></label>
                <input asp-for="Password" class="form-control" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary">Sign in</button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
