@{
    ViewData["Title"] = "Something went wrong";
}

<div class="text-center py-5">
    <h1 class="h3">Something went wrong</h1>
    <p class="text-muted">
        Sorry, an unexpected error occurred while processing your request. Please try again,
        or go back to the orders list.
    </p>
    <a class="btn btn-primary" asp-controller="Orders" asp-action="Index">Back to orders</a>
</div>
